<UserControl x:Class="MutiManagerForMe.App.Views.NotesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="32,28,32,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid Margin="0,0,0,22">
            <StackPanel>
                <TextBlock Text="Ghi chú" Style="{StaticResource PageTitle}" />
                <TextBlock Text="Lưu ý tưởng, nội dung họp và thông tin cần tra cứu." Foreground="{StaticResource TextMutedBrush}" />
            </StackPanel>
            <Button Content="＋ Ghi chú mới" Command="{Binding NewCommand}" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Right" VerticalAlignment="Center" />
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource Card}" Padding="10" Margin="0,0,18,0">
                <ListBox ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedNote}" Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14" Margin="0,0,28,0" />
                                        <TextBlock Text="●" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Right">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPinned}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                    <TextBlock Text="{Binding Preview}" Style="{StaticResource MutedText}" Margin="0,6,0,8" MaxHeight="38" />
                                    <TextBlock Text="{Binding UpdatedAt, StringFormat={}{0:dd/MM/yyyy HH:mm}}" Style="{StaticResource MutedText}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBox Text="{Binding EditorTitle, UpdateSourceTrigger=PropertyChanged}" FontSize="20" FontWeight="SemiBold" BorderThickness="0,0,0,1" Padding="0,4,0,12" />
                    <TextBox Grid.Row="1" Text="{Binding EditorContent, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap"
                             VerticalContentAlignment="Top" BorderThickness="0" Padding="0,16" VerticalScrollBarVisibility="Auto" />
                    <Grid Grid.Row="2" Margin="0,14,0,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <CheckBox Content="Ghim ghi chú" IsChecked="{Binding IsPinned}" Margin="0,0,16,0" />
                            <TextBlock Text="{Binding ValidationMessage}" Style="{StaticResource ValidationText}" VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Xóa" Command="{Binding DeleteCommand}" Style="{StaticResource DangerButton}" Margin="0,0,10,0" />
                            <Button Content="Lưu ghi chú" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButton}" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
