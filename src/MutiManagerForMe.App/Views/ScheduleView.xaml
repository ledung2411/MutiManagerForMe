<UserControl x:Class="MutiManagerForMe.App.Views.ScheduleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="32,28,32,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Margin="0,0,0,20">
            <TextBlock Text="Lịch trình" Style="{StaticResource PageTitle}" />
            <TextBlock Text="Sắp xếp ngày làm việc theo từng khung giờ." Foreground="{StaticResource TextMutedBrush}" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="12" Margin="0,0,0,18">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Button Content="‹" Command="{Binding PreviousDayCommand}" Style="{StaticResource IconButton}" />
                    <Button Content="Hôm nay" Command="{Binding TodayCommand}" Margin="8,0" />
                    <Button Content="›" Command="{Binding NextDayCommand}" Style="{StaticResource IconButton}" />
                </StackPanel>
                <TextBlock Text="{Binding SelectedDateLabel}" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                <DatePicker SelectedDate="{Binding SelectedDate}" HorizontalAlignment="Right" Width="145" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="330" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource Card}" Padding="12" Margin="0,0,18,0">
                <ListBox ItemsSource="{Binding Items}" Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="8,4,8,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="104" />
                                    <ColumnDefinition Width="5" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Top">
                                    <TextBlock Text="{Binding StartsAt, StringFormat={}{0:HH:mm}}" FontSize="16" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding EndsAt, StringFormat={}{0:HH:mm}}" Style="{StaticResource MutedText}" Margin="0,2,0,0" />
                                </StackPanel>
                                <Border Grid.Column="1" Background="{StaticResource PrimaryBrush}" CornerRadius="3" />
                                <StackPanel Grid.Column="2" Margin="16,0">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14" />
                                    <TextBlock Text="{Binding Description}" Foreground="{StaticResource TextMutedBrush}" Margin="0,5,0,0" />
                                </StackPanel>
                                <Button Grid.Column="3" Content="Xóa" Style="{StaticResource DangerButton}" VerticalAlignment="Top"
                                        Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource Card}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Thêm lịch trình" Style="{StaticResource SectionTitle}" Margin="0,0,0,18" />
                        <TextBlock Text="Tên lịch trình" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding NewTitle, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="Mô tả" Style="{StaticResource FieldLabel}" Margin="0,14,0,6" />
                        <TextBox Text="{Binding NewDescription, UpdateSourceTrigger=PropertyChanged}" Height="68" AcceptsReturn="True" VerticalContentAlignment="Top" />

                        <TextBlock Text="Thời gian" Style="{StaticResource FieldLabel}" Margin="0,14,0,6" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="28" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding StartTime}" HorizontalContentAlignment="Center" MaxLength="5" />
                            <TextBlock Grid.Column="1" Text="–" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <TextBox Grid.Column="2" Text="{Binding EndTime}" HorizontalContentAlignment="Center" MaxLength="5" />
                        </Grid>

                        <CheckBox Content="Nhắc trước lịch trình" IsChecked="{Binding EnableReminder}" Margin="0,14,0,4" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding ReminderMinutes}" IsEnabled="{Binding EnableReminder}" />
                            <TextBlock Grid.Column="1" Text="phút" Margin="8,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" />
                        </Grid>

                        <TextBlock Text="{Binding ValidationMessage}" Style="{StaticResource ValidationText}" />
                        <Button Content="Thêm vào lịch" Command="{Binding AddCommand}" Style="{StaticResource PrimaryButton}" Margin="0,18,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
