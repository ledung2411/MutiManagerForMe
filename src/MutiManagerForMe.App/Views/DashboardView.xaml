<UserControl
    x:Class="MutiManagerForMe.App.Views.DashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,28,32,36" Spacing="20">
            <Grid>
                <StackPanel>
                    <TextBlock Text="{Binding Greeting}" Style="{StaticResource PageTitle}" />
                    <TextBlock Text="{Binding TodayLabel}" Foreground="{StaticResource TextMutedBrush}" />
                </StackPanel>
                <Button Content="↻  Làm mới" Command="{Binding RefreshCommand}" HorizontalAlignment="Right" VerticalAlignment="Center" />
            </Grid>

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Việc hôm nay" Style="{StaticResource MutedText}" />
                        <TextBlock Text="{Binding TodayTaskCount}" FontSize="29" FontWeight="SemiBold" Margin="0,7,0,2" />
                        <TextBlock Text="công việc cần xử lý" Style="{StaticResource MutedText}" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Đã hoàn thành" Style="{StaticResource MutedText}" />
                        <TextBlock Text="{Binding CompletedTodayCount}" FontSize="29" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}" Margin="0,7,0,2" />
                        <TextBlock Text="trong hôm nay" Style="{StaticResource MutedText}" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Đang quá hạn" Style="{StaticResource MutedText}" />
                        <TextBlock Text="{Binding OverdueTaskCount}" FontSize="29" FontWeight="SemiBold" Foreground="{StaticResource DangerBrush}" Margin="0,7,0,2" />
                        <TextBlock Text="cần ưu tiên" Style="{StaticResource MutedText}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource Card}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Thu tháng này" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding MonthIncome}" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold" FontSize="19" Margin="0,7,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Chi tháng này" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding MonthExpense}" Foreground="{StaticResource DangerBrush}" FontWeight="SemiBold" FontSize="19" Margin="0,7,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="Ngân sách còn lại" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding BudgetRemaining}" HorizontalAlignment="Right" FontWeight="SemiBold" />
                        </Grid>
                        <ProgressBar Value="{Binding BudgetPercent}" Maximum="100" Height="8" Margin="0,12,0,4" Foreground="{StaticResource PrimaryBrush}" Background="{StaticResource SurfaceMutedBrush}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Việc cần làm" Style="{StaticResource SectionTitle}" Margin="0,0,0,14" />
                        <ListView ItemsSource="{Binding TodayTasks}" SelectionMode="None" Background="Transparent">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="0,10" ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="4" Height="28" CornerRadius="2" Background="{StaticResource PrimaryBrush}" />
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding PriorityLabel}" Style="{StaticResource MutedText}" Margin="0,3,0,0" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding DueLabel}" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <TextBlock Text="Nếu danh sách trống, hãy tạo công việc ở mục Công việc." Style="{StaticResource MutedText}" Margin="0,12,0,0" />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="1" Spacing="16">
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Lịch hôm nay" Style="{StaticResource SectionTitle}" Margin="0,0,0,14" />
                            <ListView ItemsSource="{Binding TodaySchedule}" SelectionMode="None" Background="Transparent">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,7" ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="88" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding TimeLabel}" Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="1" Text="{Binding Title}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Ghi chú đã ghim" Style="{StaticResource SectionTitle}" Margin="0,0,0,10" />
                            <ListView ItemsSource="{Binding PinnedNotes}" SelectionMode="None" Background="Transparent">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,6">
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Preview}" Style="{StaticResource MutedText}" Margin="0,3,0,0" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
