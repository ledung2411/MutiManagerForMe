<UserControl x:Class="MutiManagerForMe.App.Views.TasksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="32,28,32,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid Margin="0,0,0,22">
            <StackPanel>
                <TextBlock Text="Công việc" Style="{StaticResource PageTitle}" />
                <TextBlock Text="Lập kế hoạch, đặt nhắc việc và hoàn thành từng bước." Foreground="{StaticResource TextMutedBrush}" />
            </StackPanel>
            <CheckBox Content="Hiện việc đã hoàn thành" IsChecked="{Binding ShowCompleted}" HorizontalAlignment="Right" VerticalAlignment="Center" />
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource Card}" Margin="0,0,18,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Thêm công việc" Style="{StaticResource SectionTitle}" Margin="0,0,0,18" />
                        <TextBlock Text="Tên công việc" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding NewTitle, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="Tên công việc" />

                        <TextBlock Text="Mô tả" Style="{StaticResource FieldLabel}" Margin="0,14,0,6" />
                        <TextBox Text="{Binding NewDescription, UpdateSourceTrigger=PropertyChanged}" Height="74" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" />

                        <TextBlock Text="Hạn hoàn thành" Style="{StaticResource FieldLabel}" Margin="0,14,0,6" />
                        <DatePicker SelectedDate="{Binding DueDate}" />

                        <TextBlock Text="Mức ưu tiên" Style="{StaticResource FieldLabel}" Margin="0,14,0,6" />
                        <ComboBox ItemsSource="{Binding Priorities}" SelectedItem="{Binding SelectedPriority}" DisplayMemberPath="Label" />

                        <TextBlock Text="Lặp lại" Style="{StaticResource FieldLabel}" Margin="0,14,0,6" />
                        <ComboBox ItemsSource="{Binding RepeatOptions}" SelectedItem="{Binding SelectedRepeat}" />

                        <TextBlock Text="Nhắc lúc (không bắt buộc)" Style="{StaticResource FieldLabel}" Margin="0,14,0,6" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="82" />
                            </Grid.ColumnDefinitions>
                            <DatePicker SelectedDate="{Binding ReminderDate}" Margin="0,0,8,0" />
                            <TextBox Grid.Column="1" Text="{Binding ReminderTime}" MaxLength="5" HorizontalContentAlignment="Center" />
                        </Grid>

                        <TextBlock Text="{Binding ValidationMessage}" Style="{StaticResource ValidationText}" />
                        <Button Content="Thêm công việc" Command="{Binding AddCommand}" Style="{StaticResource PrimaryButton}" Margin="0,18,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource Card}" Padding="10">
                <Grid>
                <ListBox ItemsSource="{Binding Items}" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="10,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button Content="✓" Width="34" Height="34" Padding="0"
                                            Command="{Binding DataContext.ToggleCompletedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource SuccessBrush}" />
                                                        <Setter Property="Foreground" Value="White" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <StackPanel Grid.Column="1" Margin="8,0,18,0">
                                        <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="TextDecorations" Value="{x:Null}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                            <Setter Property="TextDecorations" Value="Strikethrough" />
                                                            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Description}" Style="{StaticResource MutedText}" Margin="0,4,0,0" MaxHeight="38" />
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <Border Style="{StaticResource Badge}" Margin="0,0,8,0">
                                                <TextBlock Text="{Binding PriorityLabel}" FontSize="10" />
                                            </Border>
                                            <Border Style="{StaticResource Badge}" Background="{StaticResource PrimarySoftBrush}">
                                                <TextBlock Text="{Binding RepeatRule}" FontSize="10" Foreground="{StaticResource PrimaryBrush}" />
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding DueLabel}" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Right" />
                                        <Button Content="Xóa" Style="{StaticResource DangerButton}" Margin="0,10,0,0"
                                                Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Items.Count}" Value="0"><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="Chưa có công việc" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" />
                        <TextBlock Text="Tạo công việc đầu tiên từ biểu mẫu bên trái." Style="{StaticResource MutedText}" Margin="0,6,0,0" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
