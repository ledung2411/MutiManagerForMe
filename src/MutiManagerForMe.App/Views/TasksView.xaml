<UserControl
    x:Class="MutiManagerForMe.App.Views.TasksView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="32,28,32,32" RowSpacing="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid>
            <StackPanel>
                <TextBlock Text="Công việc" Style="{StaticResource PageTitle}" />
                <TextBlock Text="Lập kế hoạch, đặt nhắc việc và hoàn thành từng bước." Foreground="{StaticResource TextMutedBrush}" />
            </StackPanel>
            <CheckBox Content="Hiện việc đã hoàn thành" IsChecked="{Binding ShowCompleted, Mode=TwoWay}" HorizontalAlignment="Right" VerticalAlignment="Center" />
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource Card}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Thêm công việc" Style="{StaticResource SectionTitle}" Margin="0,0,0,12" />
                        <TextBlock Text="Tên công việc" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding NewTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="Tên công việc" />

                        <TextBlock Text="Mô tả" Style="{StaticResource FieldLabel}" Margin="0,10,0,0" />
                        <TextBox Text="{Binding NewDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="74" AcceptsReturn="True" TextWrapping="Wrap" />

                        <TextBlock Text="Hạn hoàn thành" Style="{StaticResource FieldLabel}" Margin="0,10,0,0" />
                        <CalendarDatePicker Date="{Binding DueDate, Mode=TwoWay}" />

                        <TextBlock Text="Mức ưu tiên" Style="{StaticResource FieldLabel}" Margin="0,10,0,0" />
                        <ComboBox ItemsSource="{Binding Priorities}" SelectedItem="{Binding SelectedPriority, Mode=TwoWay}" DisplayMemberPath="Label" />

                        <TextBlock Text="Lặp lại" Style="{StaticResource FieldLabel}" Margin="0,10,0,0" />
                        <ComboBox ItemsSource="{Binding RepeatOptions}" SelectedItem="{Binding SelectedRepeat, Mode=TwoWay}" />

                        <TextBlock Text="Nhắc lúc (không bắt buộc)" Style="{StaticResource FieldLabel}" Margin="0,10,0,0" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="82" />
                            </Grid.ColumnDefinitions>
                            <CalendarDatePicker Date="{Binding ReminderDate, Mode=TwoWay}" />
                            <TextBox Grid.Column="1" Text="{Binding ReminderTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="5" HorizontalContentAlignment="Center" />
                        </Grid>

                        <TextBlock Text="{Binding ValidationMessage}" Style="{StaticResource ValidationText}" />
                        <Button Content="Thêm công việc" Command="{Binding AddCommand}" Style="{StaticResource PrimaryButton}" Margin="0,12,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource Card}" Padding="10">
                <Grid>
                    <ListView ItemsSource="{Binding Items}" Background="Transparent" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="10,12">
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Button Content="✓" Width="34" Height="34" Padding="0" Style="{StaticResource IconButton}" Click="ToggleTask_Click" />

                                        <StackPanel Grid.Column="1" Spacing="4">
                                            <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Description}" Style="{StaticResource MutedText}" MaxHeight="38" />
                                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
                                                <Border Style="{StaticResource Badge}">
                                                    <TextBlock Text="{Binding PriorityLabel}" FontSize="10" />
                                                </Border>
                                                <Border Style="{StaticResource Badge}" Background="{StaticResource PrimarySoftBrush}">
                                                    <TextBlock Text="{Binding RepeatRule}" FontSize="10" Foreground="{StaticResource PrimaryBrush}" />
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding DueLabel}" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Right" />
                                            <Button Content="Xóa" Style="{StaticResource DangerButton}" Margin="0,10,0,0" Click="DeleteTask_Click" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
