<UserControl x:Class="MutiManagerForMe.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="32,28,32,32">
        <TextBlock Text="Cài đặt" Style="{StaticResource PageTitle}" />
        <TextBlock Text="Quản lý dữ liệu và thông tin ứng dụng." Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,24" />

        <Border Style="{StaticResource Card}" MaxWidth="760" HorizontalAlignment="Left">
            <StackPanel>
                <TextBlock Text="Dữ liệu cục bộ" Style="{StaticResource SectionTitle}" />
                <TextBlock Text="Mọi công việc, ghi chú, lịch và giao dịch được lưu trên máy này." Foreground="{StaticResource TextMutedBrush}" Margin="0,5,0,18" />
                <TextBlock Text="Vị trí cơ sở dữ liệu" Style="{StaticResource FieldLabel}" />
                <Border Background="{StaticResource SurfaceMutedBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,14">
                    <TextBlock Text="{Binding DatabasePath}" FontFamily="Consolas" FontSize="11" />
                </Border>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Sao lưu dữ liệu" Command="{Binding BackupCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,10,0" />
                    <Button Content="Mở thư mục dữ liệu" Command="{Binding OpenDataFolderCommand}" />
                </StackPanel>
                <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource SuccessBrush}" Margin="0,12,0,0" />
            </StackPanel>
        </Border>

        <Border Style="{StaticResource Card}" MaxWidth="760" HorizontalAlignment="Left" Margin="0,18,0,0">
            <Grid>
                <StackPanel>
                    <TextBlock Text="MutiManagerForMe" Style="{StaticResource SectionTitle}" />
                    <TextBlock Text="Ứng dụng quản lý cá nhân offline cho Windows." Foreground="{StaticResource TextMutedBrush}" Margin="0,5,0,0" />
                </StackPanel>
                <TextBlock Text="{Binding Version, StringFormat=Phiên bản {0}}" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" />
            </Grid>
        </Border>
    </StackPanel>
</UserControl>
