<Application x:Class="MutiManagerForMe.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MutiManagerForMe.App"
             xmlns:vm="clr-namespace:MutiManagerForMe.App.ViewModels"
             xmlns:views="clr-namespace:MutiManagerForMe.App.Views">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/AppTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                <views:DashboardView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:TasksViewModel}">
                <views:TasksView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:NotesViewModel}">
                <views:NotesView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ScheduleViewModel}">
                <views:ScheduleView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:FinanceViewModel}">
                <views:FinanceView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                <views:SettingsView />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
