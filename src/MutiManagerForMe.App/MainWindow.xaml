<Window
    x:Class="MutiManagerForMe.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:MutiManagerForMe.App.ViewModels"
    Title="MutiManagerForMe">
    <Grid x:Name="Root" Background="{StaticResource CanvasBrush}" RequestedTheme="Light">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="244" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#151B2D" Padding="18,24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Margin="8,0,8,28">
                    <Border Width="38" Height="38" CornerRadius="10" Background="{StaticResource PrimaryBrush}" HorizontalAlignment="Left">
                        <TextBlock Text="M" Foreground="White" FontSize="19" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="MutiManager" Foreground="White" FontSize="18" FontWeight="SemiBold" Margin="0,12,0,2" />
                    <TextBlock Text="Quản lý ngày của bạn" Foreground="#8E99B5" FontSize="11" />
                </StackPanel>

                <ListView
                    x:Name="NavigationList"
                    Grid.Row="1"
                    Background="Transparent"
                    BorderThickness="0"
                    SelectionMode="Single"
                    SelectionChanged="NavigationList_SelectionChanged">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:NavigationItem">
                            <Grid Padding="12,10" ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{x:Bind Glyph}" Foreground="#AEB9D3" FontSize="17" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{x:Bind Label}" Foreground="White" FontSize="13" VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Border Grid.Row="2" Background="#20273B" CornerRadius="8" Padding="12">
                    <StackPanel>
                        <TextBlock Text="Dữ liệu cục bộ" Foreground="White" FontSize="12" FontWeight="SemiBold" />
                        <TextBlock Text="Offline • Riêng tư • Nhanh" Foreground="#8E99B5" FontSize="10" Margin="0,3,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <ContentControl x:Name="PageHost" Grid.Column="1" />
    </Grid>
</Window>
